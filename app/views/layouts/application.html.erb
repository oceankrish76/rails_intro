<!DOCTYPE html>
<html>
  <head>
    <title>MyappRubyRails</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body>
  <nav class="navbar navbar-default" role="navigation">
  <div class="container-fluid">
    <div class="navbar-header">
      <%= link_to 'RoR', root_path, class:"navbar-brand" %>
    </div>
    <ul class="nav navbar-nav navbar-right">
      <li class="nav-item"><%= link_to 'home', root_path %></li>
      <li class="nav-item"><%= link_to 'allposts', posts_path %></li>
      <li class="nav-item"><%= link_to 'catgories', categories_path %></li>
      <li class="nav-item"><%= link_to 'new post', new_post_path %></li>
      <li class="nav-item"><%= link_to 'new_user', new_user_path %></li>
      <li class="nav-item"><%= link_to 'all users', users_path %></li>
      <li class="nav-item"><%= link_to 'Tags', tags_path %></li>
    </ul>
    </div>
    </nav>
    <%= yield %>
  </body>
</html>
