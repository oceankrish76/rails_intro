<p id="notice"><%= notice %></p>

<p>
  <strong>Title:</strong>
  <%= @post.title %>
</p>

<p>
  <strong>Content:</strong>
  <%= @post.content %>
</p>

<p>
  <strong>Published:</strong>
  <%= @post.published %>
</p>
<p>
  <strong>Category:</strong>
  <%= @post.category&.name %>
</p>

<p>
  <strong>Author from db:</strong>
  <%#= @post.user.fname %>
  <%#= @post.user&.fname %>
  <%#= @post.user&.lname %>
  <%= "#{@post.user&.fname} #{@post.user&.lname}" %>
  <%#= @post.user&.lname %>

</p>

<p>
  <strong>Tags:</strong>
  <%= @post.tags.collect{|c| c.name}.join(', ') %>
</p>
<p>
  <strong>Created at:</strong>
  <%= @post.created_at %>
</p>
<% unless(@post.image.blank?) %>
    <strong>Image</strong>
    </div>
      <%= image_tag(@post.image) %>
<% end %>
<%= link_to 'Edit', edit_post_path(@post), class:"btn btn-default btn-sm" %> |
<%= link_to 'Back', posts_path, class:"btn btn-default btn-sm" %>
